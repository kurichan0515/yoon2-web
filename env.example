# Firebase設定
REACT_APP_FIREBASE_API_KEY=your_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id

# SNS設定
# 注意: 店舗情報、営業時間、基本料金は src/config/appConfig.js で直接管理します
REACT_APP_TWITTER_URL=
REACT_APP_INSTAGRAM_URL=https://www.instagram.com/yoo.n.yoo.n/
REACT_APP_LINE_URL=https://lin.ee/lyyKSqu

# Google Calendar API設定
REACT_APP_GOOGLE_API_KEY=your_google_api_key_here
REACT_APP_GOOGLE_CALENDAR_ID=your_calendar_id_here

# Google AdSense設定
# AdSenseパブリッシャーID
REACT_APP_ADSENSE_PUBLISHER_ID=ca-pub-6862900859746528
# デフォルトの広告ユニットID（サイドバー広告）
REACT_APP_ADSENSE_DEFAULT_SLOT=2647640133
# AdSenseを有効にするかどうか（true/false）
REACT_APP_ADSENSE_ENABLED=true
# 開発モード（ローカル環境でプレースホルダーを表示、true/false）
# 注意: localhostや127.0.0.1では自動的に開発モードになります
REACT_APP_ADSENSE_DEV_MODE=false

# Google Ads設定
# Google AdsコンバージョンID（形式: AW-1234567890）
# Google Adsダッシュボードの「ツールと設定」→「設定」→「アカウント設定」→「Googleタグ」で確認
REACT_APP_GOOGLE_ADS_CONVERSION_ID=AW-1234567890
# Google Adsコンバージョンラベル（コンバージョンアクション作成時に取得）
# Google Adsダッシュボードの「ツールと設定」→「測定」→「コンバージョン」で確認
REACT_APP_GOOGLE_ADS_CONVERSION_LABEL=
# ページビュー用コンバージョンラベル（任意、未設定時はREACT_APP_GOOGLE_ADS_CONVERSION_LABELを使用）
REACT_APP_GOOGLE_ADS_PAGEVIEW_CONVERSION_LABEL=
# ホットペッパー申し込み用コンバージョンラベル（任意）
REACT_APP_GOOGLE_ADS_HOTPEPPER_CONVERSION_LABEL=
# LINE予約申し込み用コンバージョンラベル（任意）
REACT_APP_GOOGLE_ADS_LINE_CONVERSION_LABEL=
# 電話タップ（Click-to-Call）用コンバージョンラベル（任意）
REACT_APP_GOOGLE_ADS_PHONE_CONVERSION_LABEL=
# Google Adsを有効にするかどうか（true/false）
REACT_APP_GOOGLE_ADS_ENABLED=false
